{
  "name": "viandeendirect-frontend",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@fontsource/roboto": "^5.0.8",
    "@mui/icons-material": "^5.14.9",
    "@mui/lab": "^5.0.0-alpha.165",
    "@mui/material": "^5.14.11",
    "@mui/x-date-pickers": "^6.14.0",
    "react-oidc-context": "^3.0.0",
    "oidc-client-ts": "^3.1.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.2",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@viandeendirect/api": "file:../gen",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "keycloak-js": "^21.1.1",
    "querystring": "^0.2.1",
    "querystring-es3": "^0.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "react-test-renderer": "^18.2.0",
    "typescript": "^5.2.2",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "start:mock-api": "REACT_APP_MOCK_API=true react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test --watchAll=false",
    "test:coverage": "react-scripts test --watchAll=false --coverage",
    "test:update": "react-scripts test --watchAll=false -u",
    "eject": "react-scripts eject",
    "build:api": "npm install --prefix ../gen && npm run build --prefix ../gen",
    "install:api": "rm -Rf ./node_modules/@viandeendirect/api && npm install ../gen",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:containers": "USE_TESTCONTAINERS=true playwright test",
    "test:e2e:containers:build": "docker build -t viandeendirect-frontend:test -f Dockerfile . && docker build -t viandeendirect-backend:test -f ../../backend/Dockerfile ..",
    "test:e2e:containers:full": "npm run test:e2e:containers:build && npm run test:e2e:containers",
    "test:prepare:containers": "npm run test:e2e:containers:build && npm run generate:test-data"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "testcontainers": "^10.7.0"
  }
}
